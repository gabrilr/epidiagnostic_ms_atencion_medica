# Copiar este archivo a .env y ajustar valores según el entorno.

DATABASE_URL=mysql+aiomysql://root:root@db:3306/atencion_medica_db
DB_ECHO=false
ENVIRONMENT=development

# JWT — DEBE ser el MISMO valor que JWT_SECRET_KEY/JWT_ALGORITHM en el
# .env de ms-personal (MS3). MS2 decodifica el mismo token que emite
# MS3 (el login solo existe ahí); si los secretos no coinciden, MS2
# rechazará con 401 cualquier token válido.
JWT_SECRET_KEY=cambia-este-secreto-en-produccion
JWT_ALGORITHM=HS256

# URL de ms-pacientes (MS1), usada para validar paciente_id.
#
# Si corres los microservicios en contenedores SEPARADOS (cada uno con
# su propio docker-compose, como están entregados), MS2 NO puede
# alcanzar a MS1 usando el nombre de servicio "db" ni "api" — esos
# nombres solo existen dentro de la red interna de CADA proyecto
# docker-compose por separado. En ese caso, usa la IP de tu máquina
# host o "host.docker.internal" (funciona en Docker Desktop / Windows /
# Mac; en Linux puede requerir --add-host):
MS_PACIENTES_BASE_URL=http://host.docker.internal:8000
MS_PACIENTES_TIMEOUT_SECONDS=5.0

# URL de ms-personal (MS3), usada para validar personal_id. Mismo
# criterio de red que MS_PACIENTES_BASE_URL de arriba.
MS_PERSONAL_BASE_URL=http://host.docker.internal:8002
MS_PERSONAL_TIMEOUT_SECONDS=5.0

# Si en el futuro unificas los microservicios bajo un mismo
# docker-compose con una red compartida (ej. una red "epidiagnostic-net"
# declarada en todos), puedes usar directamente el nombre del servicio,
# por ejemplo:
# MS_PACIENTES_BASE_URL=http://ms_pacientes_api:8000
# MS_PERSONAL_BASE_URL=http://ms_personal_api:8002

# Credenciales de Cloudinary (dashboard: https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
